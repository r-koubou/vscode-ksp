{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "rangeStrategy": "auto",
  "lockFileMaintenance": {
    "enabled": true
  },
  "timezone": "Asia/Tokyo",
  "schedule": [
    "* 9-21 * * 6,0"
  ],
  "packageRules": [
    {

      "description": "Major updates are manually reviewed",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Automerge patch and minor updates",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    }
  ],
  "ignoreDeps": [
    "vscode",
    "@types/vscode"
  ]
}
