{
    "name": "ksp",
    "displayName": "KONTAKT Script Processor (KSP)",
    "description": "Language support for NI KONTAKT(TM) Script Processor (KSP)",
    "version": "1.1.0",
    "preview": false,
    "publisher": "rkoubou",
    "homepage": "https://r-koubou.net",
    "license": "MIT",
    "keywords": [
        "KONTAKT",
        "KSP",
        "Native Instruments",
        "Computer Music",
        "DTM"
    ],
    "categories": [
        "Programming Languages",
        "Linters",
        "Snippets"
    ],
    "galleryBanner": {
        "color": "#3A3D40",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/r-koubou/vscode-ksp.git"
    },
    "bugs": {
        "url": "https://github.com/r-koubou/vscode-ksp/issues"
    },
    "icon": "resources/icon.png",
    "main": "./dist/extension.js",
    "files": [
        "dist/**/*.js",
        "language_server/**",
        "syntaxes/**",
        "snippets/**",
        "resources/**",
        "language-configuration.json",
        "package.json",
        "LICENSE",
        "README.md",
        "NOTICE.md",
        "CHANGELOG.md"
    ],
    "contributes": {
        "languages": [
            {
                "id": "ksp",
                "configuration": "./language-configuration.json",
                "aliases": [
                    "KONTAKT Script (KSP)",
                    "ksp"
                ],
                "extensions": [
                    ".ksp",
                    ".ksp.txt"
                ]
            }
        ],
        "grammars": [
            {
                "language": "ksp",
                "scopeName": "source.kontakt.ksp.rkoubou",
                "path": "./syntaxes/ksp.json"
            }
        ],
        "commands": [
            {
                "command": "ksp.lsp.restart",
                "category": "KSP",
                "title": "Restart Language Server"
            },
            {
                "command": "ksp.obfuscate",
                "category": "KSP",
                "title": "Obfuscate Code"
            }
        ],
        "configuration": {
            "type": "object",
            "properties": {
                "ksp.completion.preferSnippetInsertion": {
                    "type": "boolean",
                    "default": true,
                    "description": "Prioritize snippet insertion when possible."
                }
            }
        },
        "snippets": [
            {
                "language": "ksp",
                "path": "./snippets/declaration.json"
            },
            {
                "language": "ksp",
                "path": "./snippets/preprocessor.json"
            },
            {
                "language": "ksp",
                "path": "./snippets/statement.json"
            }
        ]
    },
    "engines": {
        "vscode": "^1.108.0"
    },
    "dependencies": {
        "markdown-it": "^14.1.1",
        "vscode-languageclient": "^10.0.0-next.21"
    },
    "extensionDependencies": [
        "ms-dotnettools.vscode-dotnet-runtime"
    ],
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^24.12.2",
        "@types/vscode": "^1.108.1",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.3.0",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src"
    }
}
